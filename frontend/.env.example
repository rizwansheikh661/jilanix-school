# ─────────────────────────────────────────────────────────────────────────────
# Frontend environment template — Sprint F2.2.
#
# Copy to `.env.local` and fill in the values your backend reports. None of
# these variables are secrets; they are inlined into the client bundle by
# Next.js and visible in DevTools. Do not put secrets in `NEXT_PUBLIC_*`.
# ─────────────────────────────────────────────────────────────────────────────

# Branding -------------------------------------------------------------------
# Displayed in the title bar, wordmark, and "What's New on …" overlay.
NEXT_PUBLIC_APP_NAME=Jilanix
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_APP_ENV=local

# Backend --------------------------------------------------------------------
# Where the NestJS API serves `/auth/login`, `/auth/me`, etc. Must include
# the `/api/v1` prefix unless your reverse proxy strips it.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Tenant resolution (development only) --------------------------------------
# In production the tenant slug is derived from `window.location.hostname`
# (e.g. `abc.jilanix.com` → `abc`); admin.jilanix.com sends no header.
# Localhost has no DNS, so dev/staging supplies the tenant via this env
# variable; the shared axios layer reads it and attaches `X-Tenant-Slug`
# on every request. Leave UNSET in production builds.
NEXT_PUBLIC_DEV_SCHOOL_SLUG=

# Legacy (deprecated, kept for one migration cycle) -------------------------
# Sprint F1.3 used `NEXT_PUBLIC_DEFAULT_SCHOOL_ID` to inject a UUID into the
# login body. The backend now resolves tenant from host/header
# (`tenant-resolver.service.ts`), so this variable is no longer consulted
# by the application and will be removed in a future sprint. Do not set it.
NEXT_PUBLIC_DEFAULT_SCHOOL_ID=
