{
  "name": "schoolos-saas",
  "version": "0.1.0",
  "description": "SchoolOS SaaS — multi-tenant school ERP monorepo. Top-level scripts proxy into backend/ until frontend lands.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm --prefix backend run build",
    "dev": "npm --prefix backend run dev",
    "start": "npm --prefix backend run start",
    "start:dev": "npm --prefix backend run start:dev",
    "lint": "npm --prefix backend run lint",
    "test": "npm --prefix backend run test",
    "typecheck": "npm --prefix backend run typecheck",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "prisma:migrate:deploy": "npm --prefix backend run prisma:migrate:deploy"
  }
}
