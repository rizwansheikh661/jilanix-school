{
  "name": "schoolos-api",
  "version": "0.1.0",
  "description": "SchoolOS SaaS — multi-tenant school ERP API",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "prisma": {
    "schema": "prisma/schema",
    "seed": "ts-node --transpile-only -r tsconfig-paths/register prisma/seed/index.ts"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "start": "node dist/apps/api/main.js",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api/main.js",
    "lint": "eslint \"{apps,src,test,prisma,scripts}/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"{apps,src,test,prisma,scripts}/**/*.ts\" --fix",
    "format": "prettier --write \"{apps,src,test,prisma,scripts}/**/*.ts\"",
    "format:check": "prettier --check \"{apps,src,test,prisma,scripts}/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=test/.*\\.e2e-spec\\.ts$",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:sprint4_5": "jest --config ./test/jest-e2e.json --testPathPattern=test/sprint4_5",
    "test:e2e:sprint6": "jest --config ./test/jest-e2e.json --testPathPattern=test/sprint6",
    "test:e2e:sprint7": "jest --config ./test/jest-e2e.json --testPathPattern=sprint7",
    "test:e2e:sprint8": "jest --config ./test/jest-e2e.json --testPathPattern=sprint8",
    "test:e2e:sprint9": "jest --config ./test/jest-e2e.json --testPathPattern=sprint9",
    "test:e2e:sprint10": "jest --config ./test/jest-e2e.json --testPathPattern=sprint10",
    "test:e2e:sprint11": "jest --config ./test/jest-e2e.json --testPathPattern=sprint11",
    "test:e2e:sprint12": "jest --config ./test/jest-e2e.json --testPathPattern=sprint12",
    "test:e2e:sprint13": "jest --config ./test/jest-e2e.json --testPathPattern=test/sprint13",
    "test:e2e:sprint14": "jest --config ./test/jest-e2e.json --testPathPattern=test/sprint14",
    "test:e2e:sprint15": "jest --config ./test/jest-e2e.json --testPathPattern=test/sprint15",
    "test:e2e:sprint16": "jest --config ./test/jest-e2e.json --testPathPattern=test/sprint16",
    "validate:env": "ts-node --transpile-only -r tsconfig-paths/register scripts/validate-env.ts",
    "check:env-example": "ts-node --transpile-only -r tsconfig-paths/register scripts/check-env-example.ts",
    "prisma:format": "prisma format --schema prisma/schema",
    "prisma:validate": "prisma validate --schema prisma/schema",
    "prisma:generate": "prisma generate --schema prisma/schema",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema",
    "prisma:migrate:status": "prisma migrate status --schema prisma/schema",
    "prisma:migrate:reset": "prisma migrate reset --schema prisma/schema",
    "prisma:studio": "prisma studio --schema prisma/schema",
    "prisma:seed": "prisma db seed",
    "db:up": "docker compose -f docker/docker-compose.yml up -d mysql",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "db:reset": "bash scripts/mysql-reset.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "@prisma/instrumentation": "^6.0.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cron-parser": "^4.9.0",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.8.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "helmet": "^8.0.0",
    "mysql2": "^3.11.0",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.24",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prisma": "^6.0.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "prisma/schema/*.prisma": [
      "prisma format --schema prisma/schema"
    ]
  }
}
