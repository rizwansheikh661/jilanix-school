# =============================================================================
# SchoolOS API — environment template
# Copy this file to `.env` for local dev. NEVER commit `.env`.
# Each section's keys mirror the EnvSchema (src/core/config/env.schema.ts).
# Keys without a `Sprint:` annotation are required from Sprint 1 onward.
# =============================================================================

# -----------------------------------------------------------------------------
# APP — required (Sprint 1)
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=schoolos-api
APP_PORT=3000
APP_HOST=0.0.0.0
APP_GLOBAL_PREFIX=api
APP_API_VERSION=v1
APP_BASE_URL=http://localhost:3000
APP_VERSION=0.1.0
APP_BUILD_SHA=local
APP_BUILD_TIME=local

# Comma-separated origin list. Use "*" only in dev, never in prod.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# Body size limit for JSON requests (e.g. "1mb", "5mb")
HTTP_BODY_LIMIT=1mb
HTTP_TRUST_PROXY=false

# -----------------------------------------------------------------------------
# LOGGER — required (Sprint 1)
# -----------------------------------------------------------------------------
# fatal | error | warn | info | debug | trace
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_REDACT_SECRETS=true
# Paths that should NOT generate one access-log line per hit (probes, metrics)
LOG_HTTP_EXCLUDE_PATHS=/health,/ready,/version,/metrics
# Sample rate for read-only `info` access logs in (0,1]. Errors+ are always 100%.
LOG_SAMPLE_RATE_INFO=1
# Set to false to drop the `service`/`env`/`version` boot-time bindings.
LOG_BASE_BINDINGS=true

# -----------------------------------------------------------------------------
# SWAGGER / OpenAPI — required (Sprint 1)
# -----------------------------------------------------------------------------
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
SWAGGER_TITLE=SchoolOS API
SWAGGER_DESCRIPTION=Multi-tenant school ERP API
SWAGGER_VERSION=0.1.0

# -----------------------------------------------------------------------------
# DATABASE — required from Sprint 1 §2 (Prisma) onward
# -----------------------------------------------------------------------------
DB_URL=mysql://app:app@localhost:3306/schoolos?connection_limit=10&pool_timeout=10&connect_timeout=10
DB_POOL_SIZE=10
DB_POOL_TIMEOUT=10
DB_LOG_QUERIES=false
DB_SLOW_QUERY_THRESHOLD_MS=250
DB_TRANSACTION_MAX_WAIT_MS=2000
DB_TRANSACTION_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# REDIS — Sprint: 3 — leave placeholder until then
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379
# REDIS_KEY_PREFIX=schoolos:dev

# -----------------------------------------------------------------------------
# JWT / AUTH — Sprint: 1 (auth module — Sprint 1, but keys arrive in Sprint 1 plan §8)
# These are OPTIONAL in Sprint 1 modules 1+2; required when AuthModule is enabled.
# -----------------------------------------------------------------------------
# JWT_PRIVATE_KEY_BASE64=
# JWT_PUBLIC_KEY_BASE64=
# JWT_ISSUER=schoolos
# JWT_AUDIENCE=schoolos-api
# JWT_ACCESS_TTL_SECONDS=900
# JWT_REFRESH_TTL_SECONDS=2592000
# AUTH_PASSWORD_PEPPER=

# -----------------------------------------------------------------------------
# AWS / S3 — Sprint: 4
# -----------------------------------------------------------------------------
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=schoolos-files-dev
# AWS_S3_KMS_KEY_ID=

# -----------------------------------------------------------------------------
# OBSERVABILITY — Sprint: 1 (config plumbing only; collectors come later)
# -----------------------------------------------------------------------------
OTEL_ENABLED=false
# OTEL_SERVICE_NAME=schoolos-api
# OTEL_EXPORTER_OTLP_ENDPOINT=

# -----------------------------------------------------------------------------
# FEATURE TOGGLES (boot-level, not per-tenant flags)
# -----------------------------------------------------------------------------
FEATURE_DEBUG_ENDPOINTS=true

# -----------------------------------------------------------------------------
# MAIL TRANSPORT — Sprint: N1 (notification email delivery)
# -----------------------------------------------------------------------------
# transport: smtp | json (json is a no-network sink for tests).
MAIL_TRANSPORT=smtp
MAIL_FROM=SchoolOS <no-reply@schoolos.local>
# Default points at the Mailpit service in docker/docker-compose.yml. In prod,
# point this at the real provider's SMTP endpoint (SES SMTP, SendGrid SMTP, …).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
