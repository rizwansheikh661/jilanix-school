// ===========================================================================
// BillingSettings — per-school billing configuration (1:1 with account)
// ===========================================================================

/// @scope PLATFORM_ONLY
/// @softDelete
/// @audit category=tenancy
///
/// Sprint 20 — per-school billing settings. Where Plan-level grace period
/// would belong but doesn't (Plan has no gracePeriodDays column), this row
/// carries it per-school. Sprint 20 default = 7 days.
model BillingSettings {
  id                 String  @id @default(uuid()) @db.Char(36)
  accountId          String  @unique(map: "uq_billing_settings_account") @map("account_id") @db.Char(36)
  schoolId           String  @unique(map: "uq_billing_settings_school") @map("school_id") @db.Char(36)
  gracePeriodDays    Int     @default(7) @map("grace_period_days")
  billingLeadDays    Int     @default(7) @map("billing_lead_days")
  autoChargeEnabled  Boolean @default(false) @map("auto_charge_enabled")
  defaultPaymentSourceId String? @map("default_payment_source_id") @db.Char(36)
  invoicePrefix      String? @map("invoice_prefix") @db.VarChar(10)
  remindersEnabled   Boolean @default(true) @map("reminders_enabled")
  reminderOffsetsJson Json?  @map("reminder_offsets_json")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy String?   @map("created_by") @db.Char(36)
  updatedBy String?   @map("updated_by") @db.Char(36)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(3)
  deletedBy String?   @map("deleted_by") @db.Char(36)
  version   Int       @default(1)

  account BillingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_billing_settings_account")

  @@map("billing_settings")
}

// ===========================================================================
// PaymentSourceConfiguration — platform-managed payment sources
// ===========================================================================

/// @scope PLATFORM_ONLY
/// @softDelete
/// @audit category=security
///
/// Sprint 20 — payment sources configured by platform admin. RAZORPAY rows
/// carry encrypted keyId/keySecret/webhookSecret. UPI/BANK rows carry
/// human-readable handle/account details. `priority` orders sources for
/// display; `isActive` gates inclusion in payment options.
///
/// SECURITY: `keySecret` and `webhookSecret` are stored encrypted using
/// the CryptoModule's symmetric envelope. Repository decrypts only when
/// needed for signing/verification.
model PaymentSourceConfiguration {
  id          String            @id @default(uuid()) @db.Char(36)
  sourceType  PaymentSourceType @map("source_type")
  name        String            @db.VarChar(120)
  description String?           @db.VarChar(500)
  isActive    Boolean           @default(true) @map("is_active")
  isDefault   Boolean           @default(false) @map("is_default")
  priority    Int               @default(0)

  // Razorpay
  razorpayKeyId          String? @map("razorpay_key_id") @db.VarChar(80)
  razorpayKeySecretEnc   String? @map("razorpay_key_secret_enc") @db.VarChar(500)
  razorpayWebhookSecretEnc String? @map("razorpay_webhook_secret_enc") @db.VarChar(500)

  // Manual sources
  upiHandle      String? @map("upi_handle") @db.VarChar(120)
  bankName       String? @map("bank_name") @db.VarChar(120)
  bankAccountNumber String? @map("bank_account_number") @db.VarChar(40)
  bankIfsc       String? @map("bank_ifsc") @db.VarChar(20)
  bankBranch     String? @map("bank_branch") @db.VarChar(120)
  bankAccountHolder String? @map("bank_account_holder") @db.VarChar(120)
  instructions   String? @db.VarChar(1000)

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy String?   @map("created_by") @db.Char(36)
  updatedBy String?   @map("updated_by") @db.Char(36)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(3)
  deletedBy String?   @map("deleted_by") @db.Char(36)
  version   Int       @default(1)

  @@index([sourceType, isActive, priority], map: "ix_payment_sources_type_active")
  @@index([isActive, isDefault], map: "ix_payment_sources_active_default")
  @@index([deletedAt], map: "ix_payment_sources_deleted_at")
  @@map("billing_payment_sources")
}
