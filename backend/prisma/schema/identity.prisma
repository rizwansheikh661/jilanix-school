// ---------------------------------------------------------------------------
// identity.prisma — Users, passwords, sessions, login events.
//
// Sprint 1 §8/§9 scope:
//   - `User`            — tenant or global identity. Email is unique within
//                         a tenant; tenantless (global) users have schoolId
//                         pinned to the platform school.
//   - `UserPassword`    — argon2id hash + parameters. Stored separately from
//                         the user row so password rotation never touches
//                         the auth-relevant columns of `users`.
//   - `UserSession`     — refresh-token row. The cleartext token (rft_<ulid>)
//                         lives only in the client; we store sha256(token)
//                         here. Rotation links the prior session via
//                         `replaced_by_session_id`; a reuse attempt against
//                         a `revoked_at IS NOT NULL` row triggers the
//                         security alert flow.
//   - `UserLoginEvent`  — append-only login attempt audit (success/failure,
//                         reason, ip, user_agent). Drives Sprint-2 lockout.
//
// Out of scope this sprint: MFA factors, recovery codes, password-reset
// tokens, oauth identities, platform-staff impersonation.
//
// Naming: snake_plural tables, snake_case columns. Composite primary key
// `(school_id, id)` on every TENANT_OWNED model so tenant-scope is enforced
// at the FK layer for all relations.
// ---------------------------------------------------------------------------

/// @scope TENANT_OWNED
/// @audit category=security
/// @audit sensitiveFields=email,phone
model User {
  id       String @default(uuid()) @db.Char(36)
  schoolId String @map("school_id") @db.Char(36)

  email           String    @db.VarChar(255)
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamp(3)
  phone           String?   @db.VarChar(20)
  phoneVerifiedAt DateTime? @map("phone_verified_at") @db.Timestamp(3)

  displayName String @map("display_name") @db.VarChar(255)
  // 'tenant' | 'global' — controls JwtClaims.scope.
  actorScope  String @default("tenant") @map("actor_scope") @db.VarChar(10)
  // 'active' | 'invited' | 'disabled' | 'locked'. Validated app-side.
  status      String @default("active") @db.VarChar(20)

  mfaEnabled Boolean @default(false) @map("mfa_enabled")
  // ULID; rotated on password change / global logout.
  tokenSalt  String  @default("") @map("token_salt") @db.VarChar(32)

  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamp(3)
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamp(3)

  // Sprint 14 — Super Admin provisioning flow seeds school_admin users with
  // an auto-generated password and `mustChangePassword=true`. The auth layer
  // forces a password reset on the next login attempt and clears the flag
  // when the new password is set. `passwordResetRequiredAt` records the
  // timestamp the flag was raised (used for audit + admin "pending reset"
  // dashboards).
  mustChangePassword      Boolean   @default(false) @map("must_change_password")
  passwordResetRequiredAt DateTime? @map("password_reset_required_at") @db.Timestamp(3)

  // W1.1 — Basic account protection (Auth Patch Plan §17). Counter increments
  // on INVALID_CREDENTIALS; at AUTH_LOCKOUT_MAX_ATTEMPTS the account is locked
  // until `lockedUntil`. Columns ship now so the migration is in place; the
  // AuthService wiring lands in a later wave.
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until") @db.Timestamp(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy String?  @map("created_by") @db.Char(36)
  updatedBy String?  @map("updated_by") @db.Char(36)
  version   Int      @default(1)

  password               UserPassword?
  sessions               UserSession[]
  loginEvents            UserLoginEvent[]
  userRoles              UserRole[]
  passwordResetRequests  PasswordResetRequest[]
  // Sections this user is the class teacher of. Relation name disambiguates
  // from any future User↔Section relations (e.g. subject teacher).
  sectionsAsClassTeacher Section[]              @relation("SectionClassTeacher")
  // Sprint 17 — parent-portal users. Back-relation for the ParentUser
  // junction model; a single User row maps to at most one alive ParentUser
  // (enforced by the partial-unique on parent_users).
  parentUsers            ParentUser[]           @relation("ParentUserUser")
  // Sprint 18 — student-portal users. Back-relation for the StudentUser
  // junction model; a single User row maps to at most one alive StudentUser
  // (enforced by the partial-unique on student_users).
  studentUsers           StudentUser[]          @relation("StudentUserUser")

  @@id([schoolId, id])
  @@unique([schoolId, email], map: "uq_users_school_email")
  @@index([schoolId, status], map: "ix_users_school_status")
  @@index([email], map: "ix_users_email")
  @@map("users")
}

/// @scope TENANT_OWNED
/// @audit category=security
/// @audit sensitiveFields=passwordHash
model UserPassword {
  id       String @default(uuid()) @db.Char(36)
  schoolId String @map("school_id") @db.Char(36)
  userId   String @map("user_id") @db.Char(36)

  // argon2id phc string ($argon2id$v=19$m=...$t=...$p=...$salt$hash). Carries
  // its own params, so future calibration changes don't require a migration.
  passwordHash String @map("password_hash") @db.VarChar(255)
  // Argon2 parameters at time of hashing — kept for telemetry / re-hash
  // detection (auth.service compares to current calibrated params).
  algorithm    String @default("argon2id") @db.VarChar(16)
  paramsJson   Json   @map("params_json")

  // Optional pepper version — incremented when AUTH_PASSWORD_PEPPER rotates.
  pepperVersion Int @default(1) @map("pepper_version")

  forceRotateAt DateTime? @map("force_rotate_at") @db.Timestamp(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy String?  @map("created_by") @db.Char(36)
  updatedBy String?  @map("updated_by") @db.Char(36)
  version   Int      @default(1)

  user User @relation(fields: [schoolId, userId], references: [schoolId, id], onDelete: Cascade, onUpdate: Restrict, map: "fk_user_passwords_user")

  @@id([schoolId, id])
  @@unique([schoolId, userId], map: "uq_user_passwords_user")
  @@index([schoolId, userId], map: "ix_user_passwords_school_user")
  @@map("user_passwords")
}

/// @scope TENANT_OWNED
/// @audit category=security
/// @audit sensitiveFields=refreshTokenHash
model UserSession {
  id       String @default(uuid()) @db.Char(36)
  schoolId String @map("school_id") @db.Char(36)
  userId   String @map("user_id") @db.Char(36)

  // sha256(refresh_token_cleartext) — stored as 64-char hex.
  refreshTokenHash    String  @unique(map: "uq_user_sessions_token_hash") @map("refresh_token_hash") @db.Char(64)
  // Chain ancestry — Sprint-1 reuse detection walks the chain on revoke.
  parentSessionId     String? @map("parent_session_id") @db.Char(36)
  replacedBySessionId String? @map("replaced_by_session_id") @db.Char(36)
  // Logical session group — every rotation in the same login chain shares
  // the same `chainId`. Logout-by-chain becomes one indexed UPDATE.
  chainId             String  @map("chain_id") @db.Char(36)

  deviceId  String? @map("device_id") @db.VarChar(64)
  ip        String? @db.VarChar(45)
  userAgent String? @map("user_agent") @db.VarChar(512)

  issuedAt   DateTime  @default(now()) @map("issued_at") @db.Timestamp(3)
  expiresAt  DateTime  @map("expires_at") @db.Timestamp(3)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamp(3)

  // When != NULL the session is no longer valid. `revokedReason` is one of
  // 'logout' | 'logout_all' | 'rotated' | 'reuse_detected' | 'admin' |
  // 'password_changed'. Validated app-side.
  revokedAt     DateTime? @map("revoked_at") @db.Timestamp(3)
  revokedReason String?   @map("revoked_reason") @db.VarChar(32)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy String?  @map("created_by") @db.Char(36)
  updatedBy String?  @map("updated_by") @db.Char(36)
  version   Int      @default(1)

  user User @relation(fields: [schoolId, userId], references: [schoolId, id], onDelete: Cascade, onUpdate: Restrict, map: "fk_user_sessions_user")

  @@id([schoolId, id])
  @@index([schoolId, userId, revokedAt], map: "ix_user_sessions_user_revoked")
  @@index([chainId], map: "ix_user_sessions_chain")
  @@index([expiresAt], map: "ix_user_sessions_expires")
  @@map("user_sessions")
}

/// @scope TENANT_OWNED
/// @audit immutable
model UserLoginEvent {
  id       String  @default(uuid()) @db.Char(36)
  schoolId String  @map("school_id") @db.Char(36)
  userId   String? @map("user_id") @db.Char(36)

  // 'login_success' | 'login_failure' | 'logout' | 'refresh_rotated' |
  // 'refresh_reused' | 'session_revoked'. Validated app-side.
  eventType String  @map("event_type") @db.VarChar(32)
  // Free-form reason on failures — 'invalid_password', 'unknown_user', ...
  reason    String? @db.VarChar(64)

  // Echo of the identifier the client used. Email is hashed at rest because
  // failed logins can probe for accounts; we want forensic value without
  // making this table itself a directory.
  identifierHash String? @map("identifier_hash") @db.Char(64)

  ip        String? @db.VarChar(45)
  userAgent String? @map("user_agent") @db.VarChar(512)

  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamp(3)

  // Restrict (not SetNull): schoolId is part of the composite PK and cannot
  // be nullable, so SetNull is structurally impossible on this FK. Audit
  // rows are immutable; users are soft-deleted in normal operation
  // (User.status), so hard-delete is a deliberate admin path that must
  // first scrub login events.
  user User? @relation(fields: [schoolId, userId], references: [schoolId, id], onDelete: Restrict, onUpdate: Restrict, map: "fk_user_login_events_user")

  @@id([schoolId, id])
  @@index([schoolId, userId, occurredAt], map: "ix_user_login_events_user_time")
  @@index([schoolId, eventType, occurredAt], map: "ix_user_login_events_type_time")
  @@map("user_login_events")
}

// ---------------------------------------------------------------------------
// RBAC — Sprint 1 §10. Foundation only:
//   - `Role`           — platform-defined role (system roles seeded at boot;
//                        tenant-defined roles ship in a later sprint).
//                        `scope = 'tenant' | 'global'` mirrors User.actorScope
//                        and constrains who the role may be assigned to.
//   - `Permission`     — catalog of permission keys. Seeded; not user-editable.
//                        `key` shape: `<resource>.<action>` (e.g. students.read).
//                        Wildcards are NOT stored here — they live on a Role's
//                        permission grants (e.g. a 'platform_admin' role grants
//                        `*`, which the matcher resolves at check time).
//   - `RolePermission` — m:n grant. Wildcard grants (`*`, `students.*`,
//                        `*.read`) may be inserted directly even if no row
//                        exists in `permissions` for that literal key — the
//                        join FK only constrains when both sides are exact
//                        keys. We model the grant as a free-form string
//                        column so wildcards round-trip cleanly.
//   - `UserRole`       — assignment. TENANT_OWNED so the global tenant-scope
//                        guard already filters reads to ctx.schoolId.
// ---------------------------------------------------------------------------

/// @scope PLATFORM_ONLY
/// @audit category=security
model Role {
  id          String  @id @default(uuid()) @db.Char(36)
  // Stable identifier — referenced by code (e.g. RoleKeys.PRINCIPAL).
  // System roles must keep a stable key forever.
  key         String  @unique(map: "uq_roles_key") @db.VarChar(64)
  name        String  @db.VarChar(128)
  description String? @db.VarChar(512)
  // 'tenant' | 'global'. A `tenant` role can only be assigned to users with
  // actor_scope='tenant'; a `global` role only to actor_scope='global'.
  scope       String  @default("tenant") @db.VarChar(10)
  // System roles are seeded by code and may not be edited or deleted by
  // tenant admins. Custom roles (when the feature lands) flip this to false.
  isSystem    Boolean @default(true) @map("is_system")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy String?  @map("created_by") @db.Char(36)
  updatedBy String?  @map("updated_by") @db.Char(36)
  version   Int      @default(1)

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([scope], map: "ix_roles_scope")
  @@map("roles")
}

/// @scope PLATFORM_ONLY
/// @audit category=security
model Permission {
  id          String  @id @default(uuid()) @db.Char(36)
  // `<resource>.<action>` — e.g. 'students.read', 'attendance.mark'.
  key         String  @unique(map: "uq_permissions_key") @db.VarChar(128)
  resource    String  @db.VarChar(64)
  action      String  @db.VarChar(64)
  description String? @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  rolePermissions RolePermission[]

  @@index([resource], map: "ix_permissions_resource")
  @@map("permissions")
}

/// @scope PLATFORM_ONLY
/// @audit category=security
model RolePermission {
  id            String  @id @default(uuid()) @db.Char(36)
  roleId        String  @map("role_id") @db.Char(36)
  // The permission key granted. May be a wildcard (`*`, `students.*`,
  // `*.read`) — we resolve at check time. `permissionId` is set when the
  // grant matches an exact catalog row; null for wildcard grants.
  permissionKey String  @map("permission_key") @db.VarChar(128)
  permissionId  String? @map("permission_id") @db.Char(36)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  createdBy String?  @map("created_by") @db.Char(36)

  role       Role        @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_role_permissions_role")
  permission Permission? @relation(fields: [permissionId], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "fk_role_permissions_permission")

  @@unique([roleId, permissionKey], map: "uq_role_permissions_role_key")
  @@index([roleId], map: "ix_role_permissions_role")
  @@index([permissionId], map: "ix_role_permissions_permission")
  @@map("role_permissions")
}

/// @scope TENANT_OWNED
/// @audit category=security
model UserRole {
  id       String @default(uuid()) @db.Char(36)
  schoolId String @map("school_id") @db.Char(36)
  userId   String @map("user_id") @db.Char(36)
  roleId   String @map("role_id") @db.Char(36)

  // Optional revocation — set when an admin removes the assignment.
  // Soft-revoke (vs row delete) preserves the audit trail.
  assignedAt DateTime  @default(now()) @map("assigned_at") @db.Timestamp(3)
  assignedBy String?   @map("assigned_by") @db.Char(36)
  // Optional time-bounded grant (Sprint-2 needs this for substitute teachers).
  expiresAt  DateTime? @map("expires_at") @db.Timestamp(3)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamp(3)
  revokedBy  String?   @map("revoked_by") @db.Char(36)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy String?  @map("created_by") @db.Char(36)
  updatedBy String?  @map("updated_by") @db.Char(36)
  version   Int      @default(1)

  user User @relation(fields: [schoolId, userId], references: [schoolId, id], onDelete: Cascade, onUpdate: Restrict, map: "fk_user_roles_user")
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_user_roles_role")

  @@id([schoolId, id])
  @@unique([schoolId, userId, roleId], map: "uq_user_roles_user_role")
  @@index([schoolId, userId, revokedAt], map: "ix_user_roles_user_revoked")
  @@index([roleId], map: "ix_user_roles_role")
  @@index([expiresAt], map: "ix_user_roles_expires")
  @@map("user_roles")
}

/// @scope TENANT_OWNED
/// @audit category=security
/// @audit sensitiveFields=tokenHash
///
/// Sprint 14 — password-reset request issued by a super-admin (or by the
/// user themselves when the auth layer detects a `mustChangePassword` flag).
/// The cleartext token is sent out-of-band (email); only the sha256 hash
/// lives on disk. `consumedAt` flips when the new password is set;
/// `cancelledAt` flips when an admin revokes an unused request.
model PasswordResetRequest {
  id       String @default(uuid()) @db.Char(36)
  schoolId String @map("school_id") @db.Char(36)
  userId   String @map("user_id") @db.Char(36)

  // sha256(token_cleartext) — 64-char hex. Unique across all tenants so
  // token reuse across schools is structurally impossible.
  tokenHash String @unique(map: "uq_password_reset_requests_token_hash") @map("token_hash") @db.Char(64)

  requestedAt DateTime  @default(now()) @map("requested_at") @db.Timestamp(3)
  expiresAt   DateTime  @map("expires_at") @db.Timestamp(3)
  consumedAt  DateTime? @map("consumed_at") @db.Timestamp(3)
  cancelledAt DateTime? @map("cancelled_at") @db.Timestamp(3)

  ip        String? @db.VarChar(45)
  userAgent String? @map("user_agent") @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(3)
  createdBy String?  @map("created_by") @db.Char(36)
  updatedBy String?  @map("updated_by") @db.Char(36)
  version   Int      @default(1)

  user User @relation(fields: [schoolId, userId], references: [schoolId, id], onDelete: Cascade, onUpdate: Restrict, map: "fk_password_reset_requests_user")

  @@id([schoolId, id])
  @@index([schoolId, userId, consumedAt], map: "ix_password_reset_requests_school_user_consumed")
  @@index([expiresAt], map: "ix_password_reset_requests_expires")
  @@map("password_reset_requests")
}
