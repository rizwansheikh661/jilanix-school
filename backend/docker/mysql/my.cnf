[mysqld]
# ---------------------------------------------------------------------------
# Character set / collation: utf8mb4 across the board so emoji, Indic scripts,
# and supplementary plane characters round-trip cleanly. Anything below this
# bar (utf8 / utf8mb3) is a footgun that bites later.
# ---------------------------------------------------------------------------
character-set-server          = utf8mb4
collation-server              = utf8mb4_0900_ai_ci
default-storage-engine        = InnoDB
default-time-zone             = '+00:00'

# ---------------------------------------------------------------------------
# Strict SQL: reject silent truncations, zero-dates, division-by-zero, engine
# substitution. Surfaces bugs at write-time instead of months later in reports.
# ---------------------------------------------------------------------------
sql_mode                      = STRICT_TRANS_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION
innodb_strict_mode            = ON
lower_case_table_names        = 1

# ---------------------------------------------------------------------------
# Durability: 1 = flush log on every commit. The "fast but lossy" values 0/2
# do not belong in any environment that runs migrations or financial flows.
# ---------------------------------------------------------------------------
innodb_flush_log_at_trx_commit = 1
innodb_doublewrite             = ON
innodb_file_per_table          = ON

# ---------------------------------------------------------------------------
# Connections & packets. max_allowed_packet bumped from default 4M because
# audit before/after JSON blobs and bulk imports sometimes exceed it.
# ---------------------------------------------------------------------------
max_connections               = 200
max_allowed_packet            = 64M
net_read_timeout              = 60
net_write_timeout             = 60
wait_timeout                  = 600
interactive_timeout           = 600

# ---------------------------------------------------------------------------
# Buffer pool. 256M is conservative for local dev. Override per-env.
# ---------------------------------------------------------------------------
innodb_buffer_pool_size       = 256M
innodb_log_file_size          = 64M
innodb_log_buffer_size        = 16M

# ---------------------------------------------------------------------------
# Slow-query log. 250ms threshold mirrors the application-level SLO. CI/dev
# uses this to surface N+1 patterns before they reach staging.
# ---------------------------------------------------------------------------
slow_query_log                = 1
slow_query_log_file           = /var/log/mysql/slow.log
long_query_time               = 0.250
log_queries_not_using_indexes = 1
log_slow_admin_statements     = 1

# ---------------------------------------------------------------------------
# Authentication: default to caching_sha2_password (MySQL 8 default). Drivers
# must support it (mysql2 does).
# ---------------------------------------------------------------------------
default_authentication_plugin = caching_sha2_password
skip-name-resolve              = ON

[client]
default-character-set         = utf8mb4

[mysql]
default-character-set         = utf8mb4
